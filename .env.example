DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/office_hours_os?schema=public"

AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_CLIENT_ID="your-auth0-client-id"
AUTH0_CLIENT_SECRET="your-auth0-client-secret"
AUTH0_SECRET="a-long-random-32-byte-hex-string"
APP_BASE_URL="http://localhost:3000"
GEMINI_API_KEY="your-gemini-api-key"
# Optional Gemini usage guardrails
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_SUMMARY_WINDOW_MS="60000"
GEMINI_SUMMARY_MAX_REQUESTS="12"
GEMINI_SUMMARY_MIN_INTERVAL_MS="1500"
GEMINI_SUMMARY_MAX_POSTS="800"
GEMINI_SUMMARY_MAX_TRANSCRIPT_CHARS="60000"
GEMINI_SUMMARY_MAX_OUTPUT_CHARS="20000"
GEMINI_SUMMARY_MAX_OUTPUT_TOKENS="2400"
GEMINI_SUMMARY_TIMEOUT_MS="30000"
